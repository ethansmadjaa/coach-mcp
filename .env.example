# Copy this file to `.env` and fill in the values below.
# `make pull-env` will overwrite .env with Railway's values once the project is deployed.

# Auto-injected by Railway when a Postgres service is linked.
# For local dev, point this at your local Postgres or run `make pull-env` after `railway add --database postgres`.
DATABASE_URL=postgresql://postgres:password@localhost:5432/coach

# GitHub OAuth App credentials.
# Create one at https://github.com/settings/applications/new
#   - Authorization callback URL: https://<your-railway-domain>/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Your GitHub login (case-sensitive) — only this user can authenticate.
ALLOWED_GITHUB_LOGIN=

# Public URL of your deployed server. Generated by `railway domain`.
BASE_URL=https://your-service.up.railway.app

# Local port. Railway sets PORT automatically in production.
PORT=8000
